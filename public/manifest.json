{
  "manifest_version": 3,
  "name": "AI Thumbnail Maker",
  "version": "1.0.0",
  "description": "Generate professional YouTube thumbnails with AI directly from your browser.",
  "action": {
    "default_popup": "index.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "permissions": ["storage"],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
